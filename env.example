# Leoma Subnet Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED (validator: evaluator + weight-setter)
# ═══════════════════════════════════════════════════════════════════════════════

# Centralized API URL (validators use for GET /tasks/latest, GET /weights, POST evaluations)
API_URL=https://api.leoma.ai

# OpenAI API key for GPT-4o evaluation (validator evaluator)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# OWNER-SAMPLER ONLY (task creation, miner calls – not needed for validators)
# ═══════════════════════════════════════════════════════════════════════════════

# Chutes API key for I2V video generation (owner-sampler only)
# Get from: https://chutes.ai
CHUTES_API_KEY=

# Object storage: Cloudflare R2 (default) or Hippius (S3-compatible API)
OBJECT_STORAGE_BACKEND=r2
# OBJECT_STORAGE_BACKEND=hippius

# ─── Hippius (when OBJECT_STORAGE_BACKEND=hippius) ───
HIPPIUS_ENDPOINT=s3.hippius.com
HIPPIUS_REGION=decentralized

# Buckets
HIPPIUS_SOURCE_BUCKET=leoma-videos
HIPPIUS_SAMPLES_BUCKET=leoma-samples

# Source bucket read credentials (sampler video picking/downloading)
HIPPIUS_VIDEOS_READ_ACCESS_KEY=
HIPPIUS_VIDEOS_READ_SECRET_KEY=

# Source bucket write credentials (corpus expansion / ingest)
HIPPIUS_VIDEOS_WRITE_ACCESS_KEY=
HIPPIUS_VIDEOS_WRITE_SECRET_KEY=

# Samples bucket read credentials (validator evaluator: download task artifacts from S3)
HIPPIUS_SAMPLES_READ_ACCESS_KEY=hip_b51df6563be3b768a4b9c80b
HIPPIUS_SAMPLES_READ_SECRET_KEY=0W4anhpzm1MXmGG7RpBt-zv2GJIiTnSEqoFaw2-sj3E

# Samples bucket write credentials (owner-sampler: sample uploads; validator does not need)
HIPPIUS_SAMPLES_WRITE_ACCESS_KEY=
HIPPIUS_SAMPLES_WRITE_SECRET_KEY=

# ─── Cloudflare R2 (default when OBJECT_STORAGE_BACKEND unset or r2) ───
# S3 API URL from R2 dashboard (scheme optional), region usually "auto"
R2_ENDPOINT=https://cce499ad4f3a4703b069771d8ff4215a.r2.cloudflarestorage.com
R2_REGION=auto
R2_SOURCE_BUCKET=leoma-videos
R2_SAMPLES_BUCKET=leoma-samples
R2_VIDEOS_READ_ACCESS_KEY=
R2_VIDEOS_READ_SECRET_KEY=
R2_VIDEOS_WRITE_ACCESS_KEY=
R2_VIDEOS_WRITE_SECRET_KEY=
R2_SAMPLES_READ_ACCESS_KEY=a15afa64fb77da5cd98a511ce20759bd
R2_SAMPLES_READ_SECRET_KEY=bec439451a21f972542b470f1bfe4f8dd71e802a983fe51cdc71477515564c45
R2_SAMPLES_WRITE_ACCESS_KEY=
R2_SAMPLES_WRITE_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# WALLET (must match ~/.bittensor/wallets/)
# ═══════════════════════════════════════════════════════════════════════════════

WALLET_NAME=default
HOTKEY_NAME=default

# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK
# ═══════════════════════════════════════════════════════════════════════════════

NETWORK=finney
NETUID=99

# ═══════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# API_URL is set in REQUIRED above (validators + owner-sampler)

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL) - For API service deployment only
# ═══════════════════════════════════════════════════════════════════════════════

# Full database URL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://leoma:leoma@localhost:5432/leoma

# Or individual components
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=leoma
POSTGRES_PASSWORD=leoma
POSTGRES_DB=leoma

# ═══════════════════════════════════════════════════════════════════════════════
# API SERVICE CONFIGURATION (for subnet owners running the API)
# ═══════════════════════════════════════════════════════════════════════════════

# API service host and port
API_HOST=0.0.0.0
API_PORT=8000

# API_BIND_ADDRESS=127.0.0.1

# CORS: comma-separated allowed origins (e.g. https://app.example.com). Unset = allow * (dev only).
# CORS_ORIGINS=

# Production: set LEOMA_ENV=production (or ENVIRONMENT=production) to require DATABASE_URL or non-default POSTGRES_PASSWORD, and to reduce tracebacks in logs.
# LEOMA_ENV=production

# Request body size limit in bytes (default 2MB). Rejects requests with larger Content-Length.
# MAX_BODY_SIZE=2097152

# Admin hotkeys (comma-separated) - can add entities to blacklist
ADMIN_HOTKEYS=

# Background task intervals (seconds)
MINER_VALIDATION_INTERVAL=300
SCORE_CALCULATION_INTERVAL=300
# Stake-weighted rank / dominance (seconds)
# SCORER_INTERVAL=1800

# Consecutive task_id window [max_id - N + 1, max_id]. No rank until max(task_id) >= N.
# Eligibility: fraction of window tasks the miner was evaluated on (default 80%).
# SCORER_TASK_WINDOW=100
# SCORER_COMPLETENESS_THRESHOLD=0.8

# Signature expiry (seconds) - signed requests older than this are rejected
SIGNATURE_EXPIRY_SECONDS=300

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL OVERRIDES
# ═══════════════════════════════════════════════════════════════════════════════

# Chutes API URL (default shown)
# CHUTES_API_URL=https://api.chutes.ai

# Database debug logging (set to true to see SQL queries)
# DATABASE_ECHO=false

# Log level for leoma logger (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# One-shot clip selection in owner-sampler
# ONE_SHOT_SCENE_THRESHOLD=0.18
# ONE_SHOT_BOUNDARY_MARGIN=0.15
# DESCRIPTION_MAX_FRAMES=12
# DESCRIPTION_FRAME_FPS=3

# Validator benchmark evaluation settings
# EVALUATION_MAX_FRAMES=12
# EVALUATION_FRAME_FPS=3
# EVALUATION_PASS_THRESHOLD=70
# EVALUATION_CRITICAL_THRESHOLD=50

MIN_VALIDATOR_STAKE=5000
VALIDATOR_SYNC_INTERVAL=600

EPOCH_LEN=180