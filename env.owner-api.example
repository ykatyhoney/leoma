# ═══════════════════════════════════════════════════════════════════════════════
# Leoma OWNER-API (coordinator) — copy to .env, then: docker compose -f docker-compose.api.yml up -d.
# Validators are added with the admin wallet (leoma validator add <hotkey> --uid <uid>), not here.
# ═══════════════════════════════════════════════════════════════════════════════

# Database (use a strong password for production)
POSTGRES_USER=leoma
POSTGRES_PASSWORD=leoma
POSTGRES_DB=leoma
# Or point at an external database instead of POSTGRES_*:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/leoma

# Admin hotkeys (comma-separated) — REQUIRED to add validators and manage the blacklist
ADMIN_HOTKEYS=

# Subnet
NETWORK=finney
NETUID=99

# Production hardening (requires a non-default DB password; trims tracebacks)
# LEOMA_ENV=production
# Lock the dashboard origin(s) in production (default allows all):
# CORS_ORIGINS=https://app.leoma.ai

# Optional dashboard enrichment:
# CHUTES_API_KEY lets the "active miner" filter read private chute info (probe works without it).
# CHUTES_API_KEY=
# PEER_VALIDATORS (peer read creds) lets the dashboard presign task media from each sampler's bucket.
# PEER_VALIDATORS=[{"hotkey":"5F...","uid":3,"bucket":"leoma-val-3","endpoint":"https://<acct>.r2.cloudflarestorage.com","region":"auto","read_access_key":"...","read_secret_key":"..."}]

# Admin CLI from this host (leoma validator add/remove/list, leoma blacklist ...) — signs with your wallet:
# API_URL=https://api.leoma.ai
# WALLET_NAME=default
# HOTKEY_NAME=default
