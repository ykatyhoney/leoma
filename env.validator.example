# ═══════════════════════════════════════════════════════════════════════════════
# Leoma VALIDATOR — copy to .env on a validator host (`leoma serve`) and fill in the blanks.
# The owner must first add your hotkey: leoma validator add <hotkey> --uid <uid>.
# ═══════════════════════════════════════════════════════════════════════════════

# Coordinator, wallet, subnet
API_URL=https://api.leoma.ai
WALLET_NAME=default
HOTKEY_NAME=default
NETWORK=finney
NETUID=99

# Evaluation LLM (Gemini) + miners' Chutes
GEMINI_API_KEY=
CHUTES_API_KEY=
# HuggingFace token — only for gated/private miner models
HF_TOKEN=

# Source-clip read creds (shared by the owner)
R2_VIDEOS_READ_ACCESS_KEY=
R2_VIDEOS_READ_SECRET_KEY=

# Your own R2 result bucket (you publish verdicts here; peers read it to aggregate)
R2_OWN_BUCKET=
R2_OWN_WRITE_ACCESS_KEY=
R2_OWN_WRITE_SECRET_KEY=
# Set these only if your bucket is on a different R2 account than the shared one:
# R2_OWN_ENDPOINT=
# R2_OWN_REGION=auto

# Read-only creds for every validator's bucket incl. yours, shared peer-to-peer
# (match the owner's allowlist: leoma validator list). One object per validator:
PEER_VALIDATORS=[{"hotkey":"5F...","uid":3,"bucket":"leoma-val-3","endpoint":"https://<acct>.r2.cloudflarestorage.com","region":"auto","read_access_key":"...","read_secret_key":"..."}]

# Miner re-validation + owner-api report cadence (seconds)
MINER_VALIDATION_INTERVAL=1200
